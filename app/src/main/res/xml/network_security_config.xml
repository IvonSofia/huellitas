<?xml version="1.0" encoding="utf-8"?>
<!--
    Configuración de seguridad de red para Huellitas.

    ─ PRODUCCIÓN (HostGator): Usa HTTPS, permitido por defecto en Android.
    ─ DESARROLLO (XAMPP):     Necesita cleartext (HTTP) hacia 10.0.2.2.

    Cuando tengas tu dominio de HostGator, agrégalo abajo si necesitas
    alguna configuración especial (normalmente HTTPS funciona sin cambios).
-->
<network-security-config>
    <!-- Permitir HTTP solo para desarrollo local con XAMPP -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="false">10.0.2.2</domain>
        <domain includeSubdomains="false">localhost</domain>
        <!-- Si pruebas desde tu celular en la misma red WiFi, agrega tu IP local: -->
        <!-- <domain includeSubdomains="false">192.168.1.X</domain> -->
    </domain-config>
</network-security-config>
